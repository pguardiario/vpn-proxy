# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored - never commit real secrets.

# NordVPN access token (Nord account -> Services -> NordVPN -> Manual setup).
TOKEN=

# Local proxy port (host + container). Unpopular high port to avoid conflicts.
PROXY_PORT=39888

# Connection settings (optional - sensible defaults applied in compose).
TECHNOLOGY=NordLynx
CONNECT=New_York
NETWORK=192.168.1.0/24
